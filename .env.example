# ============================================================================
# Aconex OAuth (User-Bound Integration) — environment configuration
# ============================================================================
# 1. Copy this file to ".env"          (cp .env.example .env)
# 2. Fill in your real values below.
# 3. Never commit the real ".env" file — only this .example template.
# ============================================================================

# --- Environment toggle ------------------------------------------------------
# "true"  -> use the Early Access (EA1) Lobby + ea1.aconex.com (testing)
# "false" -> use the Production Lobby + your live instance (e.g. ksa1.aconex.com)
ACONEX_USE_EARLY_ACCESS=true

# --- OAuth Client credentials -------------------------------------------------
# From your registered "User-Bound Integration" OAuth Client in the Lobby.
# EA credentials and Production credentials are DIFFERENT — you'll register
# a separate client for each environment.
ACONEX_CLIENT_ID=SCP_User-Bound_Integration-Test-41867_ACONEX_client_APPID

ACONEX_CLIENT_SECRET=idcscs-151a705c-88cd-4ca9-be90-6f6cd4f5f258

# --- Aconex account binding ---------------------------------------------------
# Only required if the Lobby account bound to your integration has MORE than
# one linked Aconex account. Leave blank if you only have a single account.
ACONEX_USER_ID=271341877549072414

# --- Project to query ----------------------------------------------------------
# The numeric Aconex project ID you want to query (e.g. 1879048429)
# Not required when running with --list-projects.
ACONEX_PROJECT_ID=1879048429

# --- Debugging -----------------------------------------------------------------
# Set to "true" to print masked credential info (length/prefix only, never
# the real secret) when troubleshooting auth failures.
ACONEX_DEBUG=false

# --- All Filters List Documents API (optional) --------------------------------
# Only needed if you use "node index.js --all-filters". This is a different
# style of search API that expects your Aconex org/user IDs in the request
# body (separate from the Lobby ACONEX_USER_ID above). Leave blank if unsure —
# they're simply omitted from the request if not set.
ACONEX_ORG_ID=1879049000
ACONEX_SEARCH_USER_ID=271341877549072414

# --- SQL Server (local MSSQL) — only needed when aconex.config.js has -------
# mode: 'sync' and output.sql: true
#
# THREE AUTH MODES — the code auto-detects which one you're using based on
# what's filled in below (see src/db/sqlSync.js):
#
# MODE 1 (Windows auth via native ODBC — needs msnodesqlv8, which requires
# Visual Studio Build Tools to compile):
SQL_CONNECTION_STRING=DRIVER={ODBC Driver 18 for SQL Server};SERVER=DESKTOP-9RM40QK;DATABASE=Aconex Reporting Data;Trusted_Connection=yes;TrustServerCertificate=yes;

# MODE 2 (SQL Server login — pure JavaScript, no compilation needed):
SQL_SERVER=DESKTOP-9RM40QK
# Leave SQL_PORT BLANK if SQL_SERVER above includes a named instance
# (e.g. "DESKTOP-XXXX\SQLEXPRESS") — named instances use a dynamically
# assigned port discovered via the SQL Server Browser service, not a fixed
# port. Only set SQL_PORT if you've configured a static port for that
# instance yourself, or you're using a plain hostname with no instance name.
SQL_PORT=1433
SQL_DATABASE=Aconex Reporting Data
SQL_USER=
SQL_PASSWORD=
# Local/internal SQL Server instances usually use a self-signed certificate.
SQL_TRUST_SERVER_CERT=true
SQL_ENCRYPT=true

# MODE 3 (Windows auth via Python/pyodbc — NO compilation needed at all,
# used automatically when SQL_CONNECTION_STRING and SQL_USER are both blank
# but SQL_SERVER/SQL_DATABASE above are filled in). This is the best option
# if msnodesqlv8 can't compile (no Build Tools) OR if PowerShell scripts are
# blocked by execution policy — just fill in SQL_SERVER and SQL_DATABASE
# above and leave the rest blank. Requires: pip install pyodbc
# (and the ODBC Driver for SQL Server, likely already installed if anyone
# else on your team has working Python/pyodbc SQL Server code).
PYTHON_COMMAND=python
SQL_ODBC_DRIVER=ODBC Driver 18 for SQL Server
